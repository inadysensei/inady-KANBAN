# inady KANBAN — optional configuration.
#
# Every variable here is OPTIONAL; the app runs with sane defaults if unset.
# Copy this file to ".env" and uncomment what you want to override.

# Port the custom server (Next.js + WebSocket) listens on.
# PORT=7373

# Base URL the MCP server and external API clients target. Defaults to
# http://localhost:$PORT. Usually only set this if the board runs on a
# different host/port than the client talking to it.
# INADY_KANBAN_URL=http://localhost:7373

# Max number of agent sessions (PTYs) allowed to run concurrently.
# INADY_KANBAN_MAX_CONCURRENT_AGENTS=20

# Override the agent CLI binaries if they aren't named "cursor-agent" / "claude"
# on PATH (e.g. point at an absolute path to a specific install).
# CURSOR_AGENT_BIN=cursor-agent
# CLAUDE_BIN=claude
